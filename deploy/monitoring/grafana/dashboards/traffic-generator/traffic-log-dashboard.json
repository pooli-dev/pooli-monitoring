{
  "uid": "traffic-generator-log-dashboard",
  "title": "Traffic Generator Overview",
  "tags": [
    "traffic-generator",
    "loki"
  ],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": [
      "5s",
      "10s",
      "30s",
      "1m",
      "5m",
      "15m",
      "30m",
      "1h"
    ]
  },
  "annotations": {
    "list": []
  },
  "templating": {
    "list": [
      {
        "name": "line_id",
        "type": "query",
        "datasource": "Loki",
        "query": "label_values({job=\"traffic-generator\"}, line_id)",
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "hide": 0
      },
      {
        "name": "family_id",
        "type": "query",
        "datasource": "Loki",
        "query": "label_values({job=\"traffic-generator\"}, family_id)",
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "hide": 0
      },
      {
        "name": "final_status",
        "type": "query",
        "datasource": "Loki",
        "query": "label_values({job=\"traffic-generator\"}, final_status)",
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "hide": 0
      },
      {
        "name": "last_lua_status",
        "type": "query",
        "datasource": "Loki",
        "query": "label_values({job=\"traffic-generator\"}, last_lua_status)",
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "hide": 0
      }
    ]
  },
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Throughput (events/min)",
      "datasource": "Loki",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(rate({job=\"traffic-generator\", line_id=~\"${line_id:regex}\", family_id=~\"${family_id:regex}\", final_status=~\"${final_status:regex}\"}[1m])) * 60",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Success Rate (%)",
      "datasource": "Loki",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "targets": [
        {
          "expr": "(sum(rate({job=\"traffic-generator\", final_status=\"SUCCESS\", line_id=~\"${line_id:regex}\", family_id=~\"${family_id:regex}\"}[5m])) or vector(0)) / sum(rate({job=\"traffic-generator\", line_id=~\"${line_id:regex}\", family_id=~\"${family_id:regex}\"}[5m])) * 100",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Partial Success Rate (%)",
      "datasource": "Loki",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "(sum(rate({job=\"traffic-generator\", final_status=\"PARTIAL_SUCCESS\", line_id=~\"${line_id:regex}\", family_id=~\"${family_id:regex}\"}[5m])) or vector(0)) / sum(rate({job=\"traffic-generator\", line_id=~\"${line_id:regex}\", family_id=~\"${family_id:regex}\"}[5m])) * 100",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Failure Rate (%)",
      "datasource": "Loki",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "targets": [
        {
          "expr": "(sum(rate({job=\"traffic-generator\", final_status=\"FAIL\", line_id=~\"${line_id:regex}\", family_id=~\"${family_id:regex}\"}[5m])) or vector(0)) / sum(rate({job=\"traffic-generator\", line_id=~\"${line_id:regex}\", family_id=~\"${family_id:regex}\"}[5m])) * 100",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Events by Status",
      "datasource": "Loki",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 10
      },
      "targets": [
        {
          "expr": "sum by (final_status) (rate({job=\"traffic-generator\", line_id=~\"${line_id:regex}\", family_id=~\"${family_id:regex}\", final_status=~\"${final_status:regex}\"}[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Deducted Data Total (MB)",
      "datasource": "Loki",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 5
      },
      "targets": [
        {
          "expr": "sum(sum_over_time({job=\"traffic-generator\", line_id=~\"${line_id:regex}\", family_id=~\"${family_id:regex}\", final_status=~\"${final_status:regex}\"} |= \"traffic_stream_record_done\" | json | line_format \"{{.message}}\" | logfmt | unwrap deducted_total_bytes [$__range])) / 1048576",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "API Total Data / sec (MB/s)",
      "datasource": "Loki",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 13
      },
      "targets": [
        {
          "expr": "sum(rate({job=\"traffic-generator\", line_id=~\"${line_id:regex}\", family_id=~\"${family_id:regex}\", final_status=~\"${final_status:regex}\"} |= \"traffic_stream_record_done\" | json | line_format \"{{.message}}\" | logfmt | unwrap api_total_data [5m])) / 1048576",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "API Remaining Data (avg MB)",
      "datasource": "Loki",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 13
      },
      "targets": [
        {
          "expr": "avg(avg_over_time({job=\"traffic-generator\", line_id=~\"${line_id:regex}\", family_id=~\"${family_id:regex}\", final_status=~\"${final_status:regex}\"} |= \"traffic_stream_record_done\" | json | line_format \"{{.message}}\" | logfmt | unwrap api_remaining_data [5m])) / 1048576",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "type": "bargauge",
      "title": "Top 10 line_id by Deducted Data (MB)",
      "datasource": "Loki",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 21
      },
      "targets": [
        {
          "expr": "topk(10, sum by (line_id) (sum_over_time({job=\"traffic-generator\", family_id=~\"${family_id:regex}\", final_status=~\"${final_status:regex}\"} |= \"traffic_stream_record_done\" | json | line_format \"{{.message}}\" | logfmt | unwrap deducted_total_bytes [$__interval])) / 1048576)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "type": "bargauge",
      "title": "Top 10 family_id by Events",
      "datasource": "Loki",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 21
      },
      "targets": [
        {
          "expr": "topk(10, sum by (family_id) (rate({job=\"traffic-generator\", line_id=~\"${line_id:regex}\", final_status=~\"${final_status:regex}\"}[5m])))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "type": "table",
      "title": "Recent Records",
      "datasource": "Loki",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 29
      },
      "targets": [
        {
          "expr": "{job=\"traffic-generator\", line_id=~\"${line_id:regex}\", family_id=~\"${family_id:regex}\", final_status=~\"${final_status:regex}\"} |= \"traffic_stream_record_done\"",
          "refId": "A"
        }
      ],
      "options": {
        "showHeader": true
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Latency (avg ms)",
      "datasource": "Loki",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 6,
        "y": 5
      },
      "targets": [
        {
          "expr": "avg(rate({job=\"traffic-generator\", line_id=~\"${line_id:regex}\", family_id=~\"${family_id:regex}\"} |= \"traffic_stream_record_done\" | json | logfmt | unwrap latency [5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 13,
      "type": "bargauge",
      "title": "Lua Status Count",
      "datasource": "Loki",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 5
      },
      "targets": [
        {
          "expr": "sum by (last_lua_status) (count_over_time({job=\"traffic-generator\", line_id=~\"${line_id:regex}\", family_id=~\"${family_id:regex}\"} |= \"traffic_stream_record_done\" | json | line_format \"{{.message}}\" | logfmt [5m]))",
          "refId": "A"
        }
      ]
    }
  ]
}