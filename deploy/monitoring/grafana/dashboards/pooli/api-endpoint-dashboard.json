{
  "uid": "api-endpoint-dashboard",
  "title": "API Endpoint Overview",
  "tags": ["pooli-be", "api", "prometheus"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "instance",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus-ds"},
        "query": "label_values(http_server_requests_seconds_count{application=\"pooli-be\"}, instance)",
        "includeAll": true,
        "multi": true,
        "refresh": 2
      },
      {
        "name": "uri",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus-ds"},
        "query": "label_values(http_server_requests_seconds_count{application=\"pooli-be\", instance=~\"$instance\"}, uri)",
        "includeAll": true,
        "multi": true,
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total RPS",
      "description": "선택한 pooli-be 인스턴스 전체의 API 요청 처리량을 보여줍니다.",
      "datasource": {"type": "prometheus", "uid": "prometheus-ds"},
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"pooli-be\", instance=~\"$instance\"}[5m]))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]}
      },
      "fieldConfig": {
        "defaults": {"unit": "reqps"}
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Error Rate (%)",
      "description": "선택한 인스턴스의 전체 API 요청 중 5xx 응답 비율을 보여줍니다.",
      "datasource": {"type": "prometheus", "uid": "prometheus-ds"},
      "gridPos": {"h": 5, "w": 6, "x": 6, "y": 0},
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"pooli-be\", instance=~\"$instance\", status=~\"5..\"}[5m])) / sum(rate(http_server_requests_seconds_count{application=\"pooli-be\", instance=~\"$instance\"}[5m])) * 100",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 5}
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Overall Latency P95",
      "description": "선택한 전체 요청 기준 API 응답 지연 시간의 P95를 보여줍니다.",
      "datasource": {"type": "prometheus", "uid": "prometheus-ds"},
      "gridPos": {"h": 5, "w": 6, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"pooli-be\", instance=~\"$instance\"}[5m])) by (le))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.5},
              {"color": "red", "value": 1}
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Active Endpoints",
      "description": "선택한 범위에서 요청이 발생한 고유 API URI 개수를 보여줍니다.",
      "datasource": {"type": "prometheus", "uid": "prometheus-ds"},
      "gridPos": {"h": 5, "w": 6, "x": 18, "y": 0},
      "targets": [
        {
          "expr": "count(count by (uri) (http_server_requests_seconds_count{application=\"pooli-be\", instance=~\"$instance\"}))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]}
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "RPS by Endpoint",
      "description": "HTTP 메서드와 URI별 요청 처리량 추이를 보여줍니다.",
      "datasource": {"type": "prometheus", "uid": "prometheus-ds"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 5},
      "targets": [
        {
          "expr": "sum by (uri, method) (rate(http_server_requests_seconds_count{application=\"pooli-be\", instance=~\"$instance\", uri=~\"$uri\"}[5m]))",
          "legendFormat": "{{method}} {{uri}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "reqps"}
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Latency P95 by Endpoint",
      "description": "HTTP 메서드와 URI별 응답 지연 시간 P95 추이를 보여줍니다.",
      "datasource": {"type": "prometheus", "uid": "prometheus-ds"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 5},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (uri, method, le) (rate(http_server_requests_seconds_bucket{application=\"pooli-be\", instance=~\"$instance\", uri=~\"$uri\"}[5m])))",
          "legendFormat": "{{method}} {{uri}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "s"}
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Error Rate (%) by Endpoint",
      "description": "HTTP 메서드와 URI별 5xx 오류율 추이를 보여줍니다.",
      "datasource": {"type": "prometheus", "uid": "prometheus-ds"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 13},
      "targets": [
        {
          "expr": "(sum by (uri, method) (rate(http_server_requests_seconds_count{application=\"pooli-be\", instance=~\"$instance\", uri=~\"$uri\", status=~\"5..\"}[5m])) / sum by (uri, method) (rate(http_server_requests_seconds_count{application=\"pooli-be\", instance=~\"$instance\", uri=~\"$uri\"}[5m]))) * 100",
          "legendFormat": "{{method}} {{uri}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "percent"}
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Status Code Distribution",
      "description": "HTTP 상태 코드별로 나뉜 요청 처리량을 보여줍니다.",
      "datasource": {"type": "prometheus", "uid": "prometheus-ds"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 13},
      "targets": [
        {
          "expr": "sum by (status) (rate(http_server_requests_seconds_count{application=\"pooli-be\", instance=~\"$instance\", uri=~\"$uri\"}[5m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "reqps"}
      }
    },
    {
      "id": 9,
      "type": "table",
      "title": "Top 10 Slowest Endpoints (P95)",
      "description": "P95 기준 가장 느린 API 엔드포인트 10개를 보여줍니다. UNKNOWN, actuator, favicon 요청은 제외됩니다.",
      "datasource": {"type": "prometheus", "uid": "prometheus-ds"},
      "gridPos": {"h": 10, "w": 12, "x": 0, "y": 21},
      "targets": [
        {
          "expr": "topk(10, histogram_quantile(0.95, sum by (method, uri, le) (rate(http_server_requests_seconds_bucket{application=\"pooli-be\", instance=~\"$instance\", uri!=\"UNKNOWN\", uri!~\"/actuator.*|/favicon.ico\"}[5m]))))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": ["sum"],
          "fields": "",
          "countRows": false
        }
      },
      "fieldConfig": {
        "defaults": {"unit": "s"}
      },
      "transformations": [
        {
          "id": "sortBy",
          "options": {
            "fields": {},
            "sort": [
              {
                "field": "Value",
                "desc": true
              }
            ]
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "application": true,
              "instance": true,
              "job": true
            },
            "indexByName": {
              "method": 0,
              "uri": 1,
              "Value": 2
            },
            "renameByName": {
              "method": "Method",
              "uri": "URI",
              "Value": "P95"
            }
          }
        }
      ]
    },
    {
      "id": 10,
      "type": "table",
      "title": "Top 10 Most Requested Endpoints",
      "description": "요청 비율 기준 가장 많이 호출된 API 엔드포인트 10개를 보여줍니다. UNKNOWN, actuator, favicon 요청은 제외됩니다.",
      "datasource": {"type": "prometheus", "uid": "prometheus-ds"},
      "gridPos": {"h": 10, "w": 12, "x": 12, "y": 21},
      "targets": [
        {
          "expr": "topk(10, sum by (method, uri) (rate(http_server_requests_seconds_count{application=\"pooli-be\", instance=~\"$instance\", uri!=\"UNKNOWN\", uri!~\"/actuator.*|/favicon.ico\"}[5m])))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": ["sum"],
          "fields": "",
          "countRows": false
        }
      },
      "fieldConfig": {
        "defaults": {"unit": "reqps"}
      },
      "transformations": [
        {
          "id": "sortBy",
          "options": {
            "fields": {},
            "sort": [
              {
                "field": "Value",
                "desc": true
              }
            ]
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "application": true,
              "instance": true,
              "job": true
            },
            "indexByName": {
              "method": 0,
              "uri": 1,
              "Value": 2
            },
            "renameByName": {
              "method": "Method",
              "uri": "URI",
              "Value": "RPS"
            }
          }
        }
      ]
    }
  ]
}
