        },
        {
          "type": "gauge",
          "title": "Error Rate",
          "targets": [
            {
              "expr": "rate(pooli_request_errors_total{node_name=\"db-server\"}[1m])",
              "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
              }
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "req/s",
              "min": 0,
              "color": {
                "mode": "thresholds"
              },
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  {
                    "color": "green",
                    "value": null
                  },
                  {
                    "color": "red",
                    "value": 10
                  }
                ]
              }
            }
          },
          "options": {
