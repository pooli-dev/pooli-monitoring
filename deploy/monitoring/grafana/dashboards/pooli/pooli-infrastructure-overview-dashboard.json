{
  "title": "Pooli Infrastructure Quick Overview (Grouped)",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "timezone": "browser",
  "panels": [
    {
      "type": "row",
      "title": "db-server",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "panels": [
        {
          "type": "text",
          "title": "",
          "gridPos": {
            "x": 0,
            "y": 1,
            "w": 4,
            "h": 4
          },
          "options": {
            "mode": "markdown",
            "content": "<div style=\"display:flex;align-items:center;justify-content:center;height:100%;text-align:center;\"><h2 style=\"margin:0;\">db-server</h2></div>"
          },
          "transparent": true
        },
        {
          "type": "gauge",
          "title": "CPU Busy %",
          "targets": [
            {
              "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\",node_name=\"db-server\"}[1m])) * 100)",
              "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
              }
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "percent",
              "min": 0,
              "max": 100,
              "color": {
                "mode": "thresholds"
              },
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  {
                    "color": "green",
                    "value": null
                  },
                  {
                    "color": "orange",
                    "value": 70
                  },
                  {
                    "color": "red",
                    "value": 90
                  }
                ]
              }
            }
          },
          "options": {
            "reduceOptions": {
              "values": false,
              "calcs": [
                "lastNotNull"
              ],
              "fields": ""
            },
            "showThresholdLabels": false,
            "showThresholdMarkers": true,
            "text": {}
          },
          "gridPos": {
            "x": 4,
            "y": 1,
            "w": 4,
            "h": 4
          }
        },
        {
          "type": "gauge",
          "title": "RAM Used %",
          "targets": [
            {
              "expr": "(1 - (node_memory_MemAvailable_bytes{node_name=\"db-server\"} / node_memory_MemTotal_bytes{node_name=\"db-server\"})) * 100",
              "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
              }
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "percent",
              "min": 0,
              "max": 100,
              "color": {
                "mode": "thresholds"
              },
              "thresholds": {
