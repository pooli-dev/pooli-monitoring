{
  "title": "Pooli Infrastructure Quick Overview (Grouped)",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "timezone": "browser",
  "panels": [
    {
      "type": "panel-group",
      "title": "db-server",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "panels": [
        {
          "type": "timeseries",
          "title": "CPU Busy %",
          "targets": [
            {
              "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\",node_name=\"db-server\"}[1m])) * 100)"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "percent"
            }
          },
          "gridPos": {
            "x": 0,
            "y": 1,
            "w": 4,
            "h": 4
          }
        },
        {
          "type": "timeseries",
          "title": "RAM Used %",
          "targets": [
            {
              "expr": "(1 - (node_memory_MemAvailable_bytes{node_name=\"db-server\"} / node_memory_MemTotal_bytes{node_name=\"db-server\"})) * 100"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "percent"
            }
          },
          "gridPos": {
            "x": 4,
            "y": 1,
            "w": 4,
            "h": 4
          }
        },
        {
          "type": "timeseries",
          "title": "Disk Used %",
          "targets": [
            {
              "expr": "(1 - (node_filesystem_avail_bytes{mountpoint=\"/\",node_name=\"db-server\"} / node_filesystem_size_bytes{mountpoint=\"/\",node_name=\"db-server\"})) * 100"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "percent"
            }
          },
          "gridPos": {
            "x": 8,
            "y": 1,
            "w": 4,
            "h": 4
          }
        },
        {
          "type": "timeseries",
          "title": "Error Rate",
          "targets": [
            {
              "expr": "rate(pooli_request_errors_total{node_name=\"db-server\"}[1m])"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "req/s"
            }
          },
          "gridPos": {
            "x": 12,
            "y": 1,
            "w": 4,
            "h": 4
          }
        },
        {
          "type": "timeseries",
          "title": "I/O",
          "targets": [
            {
              "expr": "rate(node_disk_read_bytes_total{node_name=\"db-server\"}[1m]) + rate(node_disk_written_bytes_total{node_name=\"db-server\"}[1m])"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "Bps"
            }
          },
          "gridPos": {
            "x": 16,
            "y": 1,
            "w": 4,
            "h": 4
          }
        }
      ]
    },
