{
  "title": "Pooli Infrastructure Quick Overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "timezone": "browser",
  "templating": {
    "list": [
      {
        "name": "servers",
        "type": "query",
        "datasource": "prometheus",
        "query": "label_values(node_cpu_seconds_total, instance)",
        "refresh": 1,
        "multi": true,
        "includeAll": true
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "$servers",
      "collapsed": false,
      "repeat": "$servers",
      "repeatDirection": "v",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "panels": [
        {
          "type": "stat",
          "title": "CPU Busy %",
          "targets": [
            {
              "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\",instance=~\"$servers\"}[1m])) * 100)"
            }
          ],
          "gridPos": { "x": 0, "y": 0, "w": 3, "h": 3 },
          "fieldConfig": { "defaults": { "unit": "percent" } }
        },
        {
          "type": "stat",
          "title": "RAM Used %",
          "targets": [
            {
              "expr": "(1 - (node_memory_MemAvailable_bytes{instance=~\"$servers\"} / node_memory_MemTotal_bytes{instance=~\"$servers\"})) * 100"
            }
          ],
          "gridPos": { "x": 3, "y": 0, "w": 3, "h": 3 },
          "fieldConfig": { "defaults": { "unit": "percent" } }
        },
        {
          "type": "stat",
          "title": "Disk Used %",
          "targets": [
            {
              "expr": "(1 - (node_filesystem_avail_bytes{mountpoint=\"/\",instance=~\"$servers\"} / node_filesystem_size_bytes{mountpoint=\"/\",instance=~\"$servers\"})) * 100"
            }
          ],
          "gridPos": { "x": 6, "y": 0, "w": 3, "h": 3 },
          "fieldConfig": { "defaults": { "unit": "percent" } }
        },
        {
          "type": "stat",
          "title": "Error Rate",
          "targets": [
            {
              "expr": "rate(pooli_request_errors_total{instance=~\"$servers\"}[1m])"
            }
          ],
          "gridPos": { "x": 9, "y": 0, "w": 3, "h": 3 },
          "fieldConfig": { "defaults": { "unit": "short" } }
        },
        {
          "type": "stat",
          "title": "I/O",
          "targets": [
            {
              "expr": "rate(node_disk_read_bytes_total{instance=~\"$servers\"}[1m]) + rate(node_disk_written_bytes_total{instance=~\"$servers\"}[1m])"
            }
          ],
          "gridPos": { "x": 12, "y": 0, "w": 3, "h": 3 },
          "fieldConfig": { "defaults": { "unit": "Bps" } }
        }
      ]
    }
  ]
}