{
  "uid": "db-query-dashboard",
  "title": "DB Query Performance",
  "tags": ["pooli-be", "mybatis", "database", "prometheus"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "mapper",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus-ds"},
        "query": "label_values(mybatis_query_duration_seconds_count{application=\"pooli-be\"}, mapper)",
        "includeAll": true,
        "multi": true,
        "refresh": 2
      },
      {
        "name": "operation",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus-ds"},
        "query": "label_values(mybatis_query_duration_seconds_count{application=\"pooli-be\", mapper=~\"$mapper\"}, operation)",
        "includeAll": true,
        "multi": true,
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Query RPS",
      "description": "선택한 범위 전체의 MyBatis 쿼리 처리량을 보여줍니다.",
      "datasource": {"type": "prometheus", "uid": "prometheus-ds"},
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "sum(rate(mybatis_query_duration_seconds_count{application=\"pooli-be\"}[5m]))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]}
      },
      "fieldConfig": {
        "defaults": {"unit": "reqps"}
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Overall Query P95",
      "description": "전체 MyBatis 쿼리 지연 시간의 P95를 보여줍니다.",
      "datasource": {"type": "prometheus", "uid": "prometheus-ds"},
      "gridPos": {"h": 5, "w": 6, "x": 6, "y": 0},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(mybatis_query_duration_seconds_bucket{application=\"pooli-be\"}[5m])) by (le))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.1},
              {"color": "red", "value": 0.5}
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Overall Query P99",
      "description": "전체 MyBatis 쿼리 지연 시간의 P99를 보여주며, 꼬리 지연을 확인할 수 있습니다.",
      "datasource": {"type": "prometheus", "uid": "prometheus-ds"},
      "gridPos": {"h": 5, "w": 6, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(mybatis_query_duration_seconds_bucket{application=\"pooli-be\"}[5m])) by (le))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.3},
              {"color": "red", "value": 1}
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Active Mappers",
      "description": "선택한 시간 구간에서 활성화된 고유 MyBatis 매퍼 수를 보여줍니다.",
      "datasource": {"type": "prometheus", "uid": "prometheus-ds"},
      "gridPos": {"h": 5, "w": 6, "x": 18, "y": 0},
      "targets": [
        {
          "expr": "count(count by (mapper) (mybatis_query_duration_seconds_count{application=\"pooli-be\"}))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]}
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Query Latency P95 by Mapper",
      "description": "매퍼별 쿼리 지연 시간 P95 추이를 보여줍니다.",
      "datasource": {"type": "prometheus", "uid": "prometheus-ds"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 5},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (mapper, le) (rate(mybatis_query_duration_seconds_bucket{application=\"pooli-be\", mapper=~\"$mapper\"}[5m])))",
          "legendFormat": "{{mapper}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "s"}
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Query Latency P95 by Operation",
      "description": "매퍼와 오퍼레이션별 쿼리 지연 시간 P95 추이를 보여줍니다.",
      "datasource": {"type": "prometheus", "uid": "prometheus-ds"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 5},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (mapper, operation, le) (rate(mybatis_query_duration_seconds_bucket{application=\"pooli-be\", mapper=~\"$mapper\", operation=~\"$operation\"}[5m])))",
          "legendFormat": "{{mapper}}.{{operation}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "s"}
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Query RPS by Mapper",
      "description": "매퍼별 쿼리 처리량 추이를 보여줍니다.",
      "datasource": {"type": "prometheus", "uid": "prometheus-ds"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 13},
      "targets": [
        {
          "expr": "sum by (mapper) (rate(mybatis_query_duration_seconds_count{application=\"pooli-be\", mapper=~\"$mapper\"}[5m]))",
          "legendFormat": "{{mapper}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "reqps"}
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Query RPS by Operation",
      "description": "매퍼와 오퍼레이션별 쿼리 처리량 추이를 보여줍니다.",
      "datasource": {"type": "prometheus", "uid": "prometheus-ds"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 13},
      "targets": [
        {
          "expr": "sum by (mapper, operation) (rate(mybatis_query_duration_seconds_count{application=\"pooli-be\", mapper=~\"$mapper\", operation=~\"$operation\"}[5m]))",
          "legendFormat": "{{mapper}}.{{operation}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "reqps"}
      }
    },
    {
      "id": 9,
      "type": "table",
      "title": "Top 10 Slowest Queries (P95)",
      "description": "현재 매퍼/오퍼레이션 필터 기준으로 P95가 가장 느린 매퍼 오퍼레이션 10개를 보여줍니다.",
      "datasource": {"type": "prometheus", "uid": "prometheus-ds"},
      "gridPos": {"h": 10, "w": 12, "x": 0, "y": 21},
      "targets": [
        {
          "expr": "topk(10, histogram_quantile(0.95, sum by (mapper, operation, le) (rate(mybatis_query_duration_seconds_bucket{application=\"pooli-be\", mapper=~\"$mapper\", operation=~\"$operation\"}[5m]))))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": ["sum"],
          "fields": "",
          "countRows": false
        }
      },
      "fieldConfig": {
        "defaults": {"unit": "s"}
      },
      "transformations": [
        {
          "id": "sortBy",
          "options": {
            "fields": {},
            "sort": [
              {
                "field": "Value",
                "desc": true
              }
            ]
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "application": true,
              "instance": true,
              "job": true
            },
            "indexByName": {
              "mapper": 0,
              "operation": 1,
              "Value": 2
            },
            "renameByName": {
              "mapper": "Mapper",
              "operation": "Operation",
              "Value": "P95"
            }
          }
        }
      ]
    },
    {
      "id": 10,
      "type": "table",
      "title": "Top 10 Most Called Queries",
      "description": "현재 매퍼/오퍼레이션 필터 기준으로 가장 많이 호출된 매퍼 오퍼레이션 10개를 보여줍니다.",
      "datasource": {"type": "prometheus", "uid": "prometheus-ds"},
      "gridPos": {"h": 10, "w": 12, "x": 12, "y": 21},
      "targets": [
        {
          "expr": "topk(10, sum by (mapper, operation) (rate(mybatis_query_duration_seconds_count{application=\"pooli-be\", mapper=~\"$mapper\", operation=~\"$operation\"}[5m])))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": ["sum"],
          "fields": "",
          "countRows": false
        }
      },
      "fieldConfig": {
        "defaults": {"unit": "reqps"}
      },
      "transformations": [
        {
          "id": "sortBy",
          "options": {
            "fields": {},
            "sort": [
              {
                "field": "Value",
                "desc": true
              }
            ]
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "application": true,
              "instance": true,
              "job": true
            },
            "indexByName": {
              "mapper": 0,
              "operation": 1,
              "Value": 2
            },
            "renameByName": {
              "mapper": "Mapper",
              "operation": "Operation",
              "Value": "RPS"
            }
          }
        }
      ]
    }
  ]
}
