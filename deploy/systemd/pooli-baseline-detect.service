[Unit]
Description=Pooli baseline anomaly detection
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/opt/pooli-monitoring
Environment=PYTHONUNBUFFERED=1
ExecStart=/opt/pooli-monitoring/.venv/bin/python -m pooli_aiops baseline-detect --settings config/settings.yaml --rules config/baseline_rules.yaml
