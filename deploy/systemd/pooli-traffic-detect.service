[Unit]
Description=Pooli traffic anomaly detection
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/opt/pooli-monitoring
Environment=PYTHONUNBUFFERED=1
ExecStart=/opt/pooli-monitoring/.venv/bin/python -m pooli_aiops detect --settings config/settings.yaml --contract config/metrics_contract.yaml
